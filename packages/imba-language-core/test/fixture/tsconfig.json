{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["esnext", "dom", "dom.iterable"],
        "strict": false,
        "noEmit": true,
        "skipLibCheck": true,
        "allowJs": true,
        "allowArbitraryExtensions": true,
        "customConditions": ["imba"]
    },
    "include": ["**/*"]
}
