{
  "name": "imba-module",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "dev": "imba -w index.html",
    "build": "imba build src/main.imba --esm",
    "watch": "imba build -w src/main.imba --esm"
  },
  "devDependencies": {
    "imba": "*"
  }
}
